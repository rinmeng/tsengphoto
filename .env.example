# Supabase Configuration
# For local development: http://localhost:8000
# For production: https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url

# Supabase anonymous/publishable key (safe for client-side use)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Supabase service role key (server-side only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# UploadThing Configuration
UPLOADTHING_TOKEN=your-uploadthing-secret
UPLOADTHING_APP_ID=your-uploadthing-app-id

# Site URL (for UploadThing callbacks on Vercel)
# For local development: http://localhost:3000
# For production: https://your-domain.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000